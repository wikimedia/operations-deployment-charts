{{/* httpd_cas auth proxy container */}}
{{- define "auth_proxy.httpd_cas.container" }}
- name: {{ template "base.name.release" . }}-httpd-cas
  image: {{ .Values.docker.registry }}/{{ .Values.auth_proxy.httpd_cas.image }}:{{ .Values.auth_proxy.httpd_cas.version }}
  imagePullPolicy: {{ .Values.docker.pull_policy }}
  ports:
  - containerPort: {{ .Values.auth_proxy.httpd_cas.port }}
    protocol: TCP
  env:
  - name: APACHE_RUN_PORT
    value: "{{ .Values.auth_proxy.httpd_cas.port }}"
  {{- include "base.helper.resources" .Values.auth_proxy.httpd_cas.resources | indent 2 }}
  livenessProbe:
    tcpSocket:
      port: {{ .Values.auth_proxy.httpd_cas.port }}
  readinessProbe:
    httpGet:
      path: /health_check
      port: {{ .Values.auth_proxy.httpd_cas.port }}
  volumeMounts:
  - name: {{ template "base.name.release" . }}-httpd-cas-site-volume
    mountPath: /etc/apache2/sites-enabled
  - name: {{ template "base.name.release" . }}-httpd-cas-health-check-volume
    mountPath: /var/www
  - name: {{ template "base.name.release" . }}-httpd-cas-cookies-volume
    mountPath: {{ .Values.auth_proxy.httpd_cas.cookies_path }}
  {{- include "base.helper.restrictedSecurityContext" . | nindent 2 }}
{{- end -}}

{{ define "auth_proxy.httpd_cas.volume" }}
# httpd_cas site configuration
- name: {{ template "base.name.release" . }}-httpd-cas-site-volume
  configMap:
    name: {{ template "base.name.release" . }}-httpd-cas-site
# httpd_cas health-check data
- name: {{ template "base.name.release" . }}-httpd-cas-health-check-volume
  configMap:
    name: {{ template "base.name.release" . }}-httpd-cas-health-check
# httpd_cas cookies store
- name: {{ template "base.name.release" . }}-httpd-cas-cookies-volume
  emptyDir:
    sizeLimit: {{ .Values.auth_proxy.httpd_cas.cookies_size_limit }}
{{- end }}

{{ define "auth_proxy.httpd_cas.configmap" }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ template "base.name.release" . }}-httpd-cas-site
  {{- include "base.meta.labels" . | indent 2 }}
  namespace: {{ .Release.Namespace }}
data:
  {{ $.Values.auth_proxy.httpd_cas.site.conf_name }}.conf: |
    # Config generated by Helm
    <VirtualHost *:{{ $.Values.auth_proxy.httpd_cas.port }}>
        ServerName {{ $.Values.auth_proxy.httpd_cas.site.server_name }}
        ServerSignature Off

        # Not used since this VHost will only act as proxy,
        # but it is needed to avoid error messages in the httpd
        # logs and logrotate crons.
        DocumentRoot /var/www

        CASLoginURL {{ $.Values.auth_proxy.httpd_cas.site.cas_login_url }}
        CASValidateURL {{ $.Values.auth_proxy.httpd_cas.site.cas_validate_url }}
        CASDebug {{ $.Values.auth_proxy.httpd_cas.site.cas_debug }}
        CASRootProxiedAs {{ $.Values.auth_proxy.httpd_cas.site.cas_root_proxied_as }}
        CASCookiePath {{ $.Values.auth_proxy.httpd_cas.cookies_path }}
        CASVersion 2
        CASCertificatePath /etc/ssl/certs
        CASAttributePrefix X-CAS-
        CASAttributeDelimiter :
        CASValidateSAML Off
        CASSSOEnabled On
        CASCookieSameSite Lax
        CASCookieSecure On
        CASTimeout 7200
        CASIdleTimeout 3600

        <Directory />
            Options FollowSymLinks
            AllowOverride None
            Require all denied
            <Files health_check>
                Require all granted
            </Files>
        </Directory>

        <Location />
              AuthType CAS
              CASAuthNHeader CAS-User
              CASScope /
              {{- range $ldapGroup := $.Values.auth_proxy.httpd_cas.site.cas_ldap_groups }}
              Require cas-attribute memberOf:cn={{$ldapGroup}},ou=groups,dc=wikimedia,dc=org
              {{- end }}
        </Location>

        <Location /health_check>
            Require all granted
            Alias {{ $.Values.auth_proxy.httpd_cas.site.health_check_path }}
        </Location>

        # Redirecting logs to stdout and stderr
        CustomLog /dev/stdout combined
        ErrorLog /dev/stderr
        LogLevel warn

        ProxyPass /health_check !
        ProxyPass / http://localhost:{{$.Values.auth_proxy.httpd_cas.target_port}}/
        ProxyPassReverse / http://localhost:{{$.Values.auth_proxy.httpd_cas.target_port}}/
    </VirtualHost>
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ template "base.name.release" . }}-httpd-cas-health-check
  {{- include "base.meta.labels" . | indent 2 }}
  namespace: {{ .Release.Namespace }}
data:
  health_check: |
    OK
{{- end }}
